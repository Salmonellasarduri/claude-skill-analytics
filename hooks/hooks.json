{
  "description": "Logs every Skill tool invocation to JSONL for usage analytics",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/skill_usage_logger.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
